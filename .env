# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB is no longer used. The database is now stored in data/db.json.
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32  (produces ~44 base64 chars)
NEXTAUTH_SECRET=your-32-byte-base64-encoded-secret-here

# ── Admin credentials (used for the admin-login NextAuth provider) ─────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# ── Mail / Inbox domain ────────────────────────────────────────────────────────
MAIL_DOMAIN=mail.example.com

# ── Webhook secret (for incoming mail webhook validation) ─────────────────────
WEBHOOK_SECRET=replace-with-a-random-secret

# ── Discord bot ────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_BOT_PREFIX=!
DISCORD_OWNER_IDS=123456789012345678

# ── Discord backup channel ─────────────────────────────────────────────────────
# Channel where the bot sends the db.json backup zip every 6 hours.
# Defaults to 1483398610828922891 if not set.
BACKUP_CHANNEL_ID=1483398610828922891

# ── Public website URL (used by the Discord bot) ──────────────────────────────
WEBSITE_URL=http://localhost:3000

# ── IMAP (catch-all inbox polling for temp-mail routing) ──────────────────────
# The catch-all mailbox that receives all @novacloud.tech emails.
IMAP_HOST=mail.novacloud.tech
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=catchall@novacloud.tech
IMAP_PASS=replace-with-catchall-password

# ── Mail domain for generated addresses ────────────────────────────────────────
MAIL_DOMAIN=novacloud.tech

# ── Mailcow integration ────────────────────────────────────────────────────────
# Base URL of your self-hosted Mailcow instance (no trailing slash).
# Leave blank to disable Mailcow integration (inboxes still work via IMAP).
MAILCOW_URL=https://mail.example.com
# API key from Mailcow → Configuration → Access → API (read+write).
MAILCOW_API_KEY=replace-with-mailcow-api-key
# If your Mailcow instance uses a self-signed certificate, set:
# NODE_TLS_REJECT_UNAUTHORIZED=0
