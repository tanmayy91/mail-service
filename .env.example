# ════════════════════════════════════════════════════════════════════
#  MailDrop — Environment Variables Reference
#
#  QUICKSTART:  npm run setup
#               → auto-generates a ready-to-deploy .env with random secrets.
#
#  Manual setup: copy this file to .env and fill in the values below.
#               cp .env.example .env
# ════════════════════════════════════════════════════════════════════

# ── NextAuth ─────────────────────────────────────────────────────────────────
# REQUIRED. Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Full public URL of this deployment (no trailing slash).
# Local dev: http://localhost:3000
# Railway:   https://<service-name>.up.railway.app
NEXTAUTH_URL=http://localhost:3000

# ── Admin panel credentials ───────────────────────────────────────────────────
# These are used to log in at  /admin  via the built-in admin provider.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# ── Mail domain ───────────────────────────────────────────────────────────────
# Domain used for generated inbox addresses.
# Addresses will look like:  randomstring@mail.yourdomain.com
MAIL_DOMAIN=mail.yourdomain.com

# ── Webhook secret ────────────────────────────────────────────────────────────
# Shared secret between your mail gateway (Mailcow filter / Haraka / Postfix)
# and this app.  Send as the  X-Webhook-Secret  header when POSTing to
# /api/webhook/receive.  Leave blank to disable auth on the webhook endpoint.
# Generate with:  openssl rand -hex 24
WEBHOOK_SECRET=replace-with-openssl-rand-hex-24

# ── Public website URL (used by the Discord bot in DMs and embeds) ────────────
# Typically the same value as NEXTAUTH_URL.
WEBSITE_URL=https://yourdomain.com

# ── Discord bot ───────────────────────────────────────────────────────────────
# Required to run the Discord bot service.
# Create an application and get a token at https://discord.com/developers
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Prefix for bot commands.  Default if omitted: .   (e.g.  .register)
DISCORD_BOT_PREFIX=.

# Comma-separated Discord user IDs that can use owner-only commands
# (e.g. !stats, !topup).  Find yours: Discord → Settings → Advanced → Developer Mode
DISCORD_OWNER_IDS=123456789012345678

# Channel ID where the bot posts automatic db.json backups every 6 hours.
# Set to 0 or leave blank to disable backups.
BACKUP_CHANNEL_ID=0

# ── IMAP catch-all ────────────────────────────────────────────────────────────
# The MailDrop IMAP service polls this mailbox for new messages and routes them
# to the correct in-app inbox.  Use your Mailcow catch-all mailbox credentials.
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=catchall@mail.yourdomain.com
IMAP_PASS=your-catchall-imap-password

# ── Mailcow integration (optional but recommended) ────────────────────────────
# When MAILCOW_URL and MAILCOW_API_KEY are both set, MailDrop will:
#   • Automatically create an alias on Mailcow for every new inbox
#   • Automatically delete the alias when an inbox is deleted
#   • Let admins manage domains & mailboxes from the Admin → Mailcow tab
#
# Leave both blank to disable.  Inboxes still work via the IMAP catch-all.
#
# Base URL of your Mailcow instance — no trailing slash.
MAILCOW_URL=https://mail.yourdomain.com
# API key from Mailcow → Configuration → Access → API  (read + write)
MAILCOW_API_KEY=your-mailcow-api-key-here
#
# If your Mailcow uses a self-signed TLS certificate uncomment:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ── Railway / server port ─────────────────────────────────────────────────────
# Set automatically by Railway.  Only needed for non-Railway deployments.
# PORT=3000
